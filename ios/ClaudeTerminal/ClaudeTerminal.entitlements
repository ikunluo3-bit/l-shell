<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Raise the app's jetsam memory ceiling so the embedded Node/V8 heap has room on
	     a real device. (Extended Virtual Addressing is the other half but personal/free
	     teams can't use it — see notes.) -->
	<key>com.apple.developer.kernel.increased-memory-limit</key>
	<true/>
</dict>
</plist>
